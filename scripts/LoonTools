set -eo pipefail # Exit on error and handle errors in pipelines
IFS=$'\n\t' # Handle spaces in filenames

# Script Constants >>>

VERSION=1.1.0

# Installation paths and names
GROUP_NAME="loon-env-users"
PATH_INSTALL="/opt/loon-env"
LOONE_SCRIPT_INSTALL="/usr/local/bin/LoonE"
CONFIG_MTU_SCRIPT_INSTALL="/usr/local/bin/configMTU"
SCRIPTS_SOURCE="./src/scripts"
LOONE_SOURCE=$SCRIPTS_SOURCE/LoonE
ASSETS_DIR="./src/assets"
WORKSPACE_DIR="$HOME/LoonE_ws"
GROUP_NAME="loon-env-users"
LOCKFILE="${LOCKFILE:-/tmp/LoonTools.lock}"


# Colors for stdout
PRIMARY=$(tput sgr0)
RED=$(tput setaf 9)
GREEN=$(tput setaf 2)
YELLOW=$(tput setaf 3)
ORANGE=$(tput setaf 202)
BLUE=$(tput setaf 4)
BOLD=$(tput bold)

# Report Constants >>>

## TYPES
DIRECTORY_TYPE=0
FILE_TYPE=1

## Status
MISSING=0
INVALID=1
VALID=2
NOT_CHECKED=3

#######################################
# Dictionary to check for in environment
# Globals:
# USER
# Format:
#   
# Dictionary value types:
#   string, boolean | null , boolean | null
# null means data not set because it has not been checked.
#######################################
declare -A REQUIRED_VARIABLES
REQUIRED_VARIABLES=(
    ["RMW_IMPLEMENTATION"]="rmw_cyclonedds_cpp"
    ["ROS_DOMAIN_ID"]="0"
    ["ROS_LOCALHOST_ONLY"]="0"
    ["ZED_SDK_VERSION"]='5.1.2'
    ["L4T_VERSION"]='R36.4.7'
    ["ROS_DISTRO"]="humble"
    ["XAUTHORITY"]="/home/$(whoami)/.Xauthority"
)

# #################################
# Dictionary to track variable status
# Globals:
# REQUIRED_VARIABLES
# NOT_CHECKED
# Format:
#   "variable"="status"
# Dictionary value types:
#   $MISSING | $INVALID | $VALID | $NOT_CHECKED
# #################################
declare -A REQUIRED_VARIABLE_STATUS
# set all keys to not checked initially
for key in "${!REQUIRED_VARIABLES[@]}"; do
    REQUIRED_VARIABLE_STATUS["$key"]="$NOT_CHECKED"
done

#######################################
# Dictionary to check for in file structure
# Globals:
#  WORKSPACE_DIR
#  DIRECTORY_TYPE
#  FILE_TYPE
# Format:
#   "path/to/file_or_directory"=type
# Dictionary value types:
#   "$FILE_TYPE" | "$DIRECTORY_TYPE"
#######################################
declare -A CORRECT_FILE_STRUCTURE
CORRECT_FILE_STRUCTURE=(
    ["$WORKSPACE_DIR"]="$DIRECTORY_TYPE"
    ["$WORKSPACE_DIR/zed_ws"]="$DIRECTORY_TYPE"
    ["$WORKSPACE_DIR/zed_ws/src"]="$DIRECTORY_TYPE"
    ["$WORKSPACE_DIR/loon_ws"]="$DIRECTORY_TYPE"
    ["$WORKSPACE_DIR/loon_ws/src"]="$DIRECTORY_TYPE"
    ["$WORKSPACE_DIR/docker/LoonE/Dockerfile"]="$FILE_TYPE"
    ["$WORKSPACE_DIR/docker/Zedx/Dockerfile"]="$FILE_TYPE"
    ["$WORKSPACE_DIR/docker/compose.yaml"]="$FILE_TYPE"
)

########################################
# Dictionary to track file structure status
# Globals:
#  CORRECT_FILE_STRUCTURE
#  NOT_CHECKED
# Format:
#   "path/to/file_or_directory"=status
# Dictionary value types:
#   $MISSING | $INVALID | $VALID | $NOT_CHECKED
#########################################
declare -A FILE_STRUCTURE_STATUS
for key in "${!CORRECT_FILE_STRUCTURE[@]}"; do
    FILE_STRUCTURE_STATUS["$key"]="$NOT_CHECKED"
done

#######################################
# Required commands for LoonE to function
# Globals:
# NOT_CHECKED
# Format:
#   "command"=present?"
# Dictionary value types:
#  $VALID | $MISSING | $NOT_CHECKED
#########################################
declare -A REQUIRED_COMMANDS
REQUIRED_COMMANDS=(
    ["apt-get"]="$NOT_CHECKED"
    ["ca-certificates"]="$NOT_CHECKED"
    ["curl"]="$NOT_CHECKED"
    ["gnupg"]="$NOT_CHECKED"
    ["gpg"]="$NOT_CHECKED"
    ["lsb-release"]="$NOT_CHECKED"
    ["wget"]="$NOT_CHECKED"
    ["git"]="$NOT_CHECKED"
    ["nvidia-smi"]="$NOT_CHECKED"
    ["colcon"]="$NOT_CHECKED"
)

# <<< Report constants

# <<< Script Constants

# Script Arguments >>>
SHIFT_ARGS_BY=1 # Used for shifting arguments
VERBOSE=0 # Verbose mode
DRY_RUN=0 # Dry running (debug)

# <<< Script Arguments

# <<< Utility Functions

#######################################
# Logs to stdout if $VERBOSE true
# Globals:
# VERBOSE
# GREEN
# BOLD
# PRIMARY
# Arguments:
#   $* - the msg
# Returns:
# Nothing
#######################################
log() {
    if [[ "$VERBOSE" -eq 1 ]]; then
        echo "${GREEN}${BOLD}[INFO] ${PRIMARY}$*"
    fi
}

#######################################
# Prints Error; does not exit
# Globals:
# RED
# BOLD
# PRIMARY
# Arguments:
#   $* - the msg
# Returns:
# Nothing
#######################################
error() {
    echo "${RED}${BOLD}[ERROR] ${PRIMARY}$*" >&2
}

#######################################
# Prints warning
# Globals:
# ORANGE
# BOLD
# PRIMARY
# Arguments:
#   $* - the msg
# Returns:
# Nothing
#######################################
warn() {
    echo "${ORANGE}${BOLD}[WARN] ${PRIMARY}$*" >&2
}

#######################################
# Runs a command unless $DRY_RUN is true then it prints it to sdtout
# Globals:
# YELLOW
# BOLD
# PRIMARY
# Arguments:
#   $1 - the command
# Returns:
# Either the string of the command or executes the command with eval
#######################################
run() {
    if [[ "$DRY_RUN" -eq 1 ]]; then
        echo "${YELLOW}${BOLD}[DRY RUN] ${PRIMARY} $*"
    else
        eval "$@"
    fi
}

#######################################
# Checks if the required command exists and exits if not
# Globals:
# BLUE
# PRIMARY
# Arguments:
#   $1 - the command
# Returns:
# Nothing, exits if commmand is missing
#######################################
require_command() {
    command -v "$1" >/dev/null 2>&1 || {
        error Missing required command: ${BLUE} "$1" ${PRIMARY} Please install and retry.
        exit 1
    }
}



#######################################
# Asks on stdout using read for confirmation
# Globals:
# BOLD
# PRIMARY
# REPLY
# Arguments:
#   $1 - prompt string
# Returns:
#   0 if yes
#   1 if no
#######################################
confirm() {
    local prompt="${1:-Are you sure?}"
    local reply
    while true; do
        read -n 1 -r -p "${prompt} ${BOLD}[y/n]${PRIMARY}: "
        echo 
        case "$REPLY" in
            [Yy]) return 0;;
            [Nn]) return 1;;
            *) printf "Please enter y or n.\n";;
        esac
    done
}

#########################################
# Check if the script is run as root
# Globals:
#  EUID
# Arguments:
#  None
# Outputs:
#  Exits with an error message if run as root
#########################################
require_non_root() {
    if [[ "$EUID" -eq 0 ]]; then
        echo "This script must not be run as root. Please use a regular user account." >&2
        exit 1
    fi
}

# Lockfile Utility >>>

#######################################
# Create lock file to prevent concurrent installations
# Globals:
#  LOCKFILE
# Arguments:
#  None
# Outputs:
#  Writes the current process ID to the lock file
#######################################
create_lock() {
    log "Creating installation lock at $LOCKFILE..."
    run 'echo "$$" > "$LOCKFILE"'    
}

#########################################
# Remove lock file on exit
# Globals:
#  LOCKFILE
# Arguments:
#  None
# Outputs:
#  Removes the lock file
#########################################
cleanup() {
    log "Cleaning up installation lock..."
    run rm -f "$LOCKFILE"
}

# <<< Lockfile Utility

# Zed Utility Functions >>>

#######################################
# Parses zed version
# Globals:
# Arguments:
#   None
# Outputs:
# x.x.x version detected or nothing
#######################################
parse_zed_version(){
    local ZED_VERSION
    ZED_VERSION=$(sudo grep 'set(PACKAGE_VERSION "' /usr/local/zed/zed-config-version.cmake 2>/dev/null | sed -E 's/set\(PACKAGE_VERSION "(.*)"\)/\1/')
    echo "$ZED_VERSION"
}

#######################################
# Determines Zed_x_daemon service status 
# Globals:
# Arguments:
#   None
# Returns:
# Gets the status of offline, restarting, online 
#######################################
get_zed_daemon_status(){
    # if we are in a container we don't have systemctl so we have to use the command directly
    if in_container; then
        local output=$(sudo /usr/local/zed/zed_x_daemon --status 2>&1 || echo "offline")
        if [[ "$output" == *"online"* ]]; then
            echo "online"
        elif [[ "$output" == *"restarting"* ]]; then
            echo "restarting"
        else
            echo "offline"
        fi
    else
        local status=$(systemctl is-active zed_x_daemon 2>/dev/null || echo "offline")
        if [[ "$status" == "active" ]]; then
            echo "online"
        elif [[ "$status" == "activating" ]]; then
            echo "restarting"
        else
            echo "offline"
        fi
    fi
}

#######################################
# attempts to restart zed_x_daemon service 
# Globals:
# Arguments:
#   None
# Returns:
# Nothing
#######################################
restart_zed_daemon(){
    log "Attempting to restart Zed Daemon..."
    # if we are in a container we don't have systemctl so we have to use the command directly
    if in_container; then
        run "sudo /usr/local/zed/zed_x_daemon --restart"
        return
    else
        run "sudo systemctl restart zed_x_daemon"
    fi
}


###################################
# Checks if zed daemon is online and attempts to restart if not
# Globals:
# Arguments:
#   None
# Returns:
# 0 if online or successfully restarted, 1 if failed to restart
###################################
check_zed_daemon(){
    local status=$(get_zed_daemon_status)
    if [[ "$status" != "online" ]]; then
        warn "Zed Daemon is not online. Attempting to restart..."
        for i in {1..3}; do
            log "Restart attempt $i..."
            restart_zed_daemon
            sleep 5 # Wait for a few seconds to allow the service to restart
            status=$(get_zed_daemon_status)
            if [[ "$status" != "online" ]]; then
                error "Failed to restart Zed Daemon. Current status: $status"
                continue
            else
                log "Zed Daemon restarted successfully and is now online."
                return 0
            fi
        done
    else
        log "Zed Daemon is online."
        return 0
    fi
}

