# L4T Utility Functions >>>

#######################################
# Parses L4T version
# Globals:
# Arguments:
#   None
# Outputs:
# echo Rx.x.x version detected or nothing
#######################################
parse_l4t_version(){
    local L4T_VERSION
    L4T_VERSION="$(sed -n 's/^# \(R[0-9]\+\).*, REVISION: \([0-9.]\+\).*/\1.\2/p' /etc/nv_tegra_release 2>/dev/null || echo "unknown")"
    echo "$L4T_VERSION"
}

