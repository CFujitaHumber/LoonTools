########################################
# Checks if the global variables are set and valid
# Globals:
# RMW_IMPLEMENTATION
# ROS_DOMAIN_ID
# ROS_LOCALHOST_ONLY
# ZED_SDK_VERSION
# L4T_VERSION
# ROS_DISTRO
# XAUTHORITY
# LOONE_FILES_DIR
# LOONE_WORKSPACE_DIR
# LOONE_SETUP_SCRIPT
# Arguments:
#  none
# Outputs:
# array of any variables that are missing or invalid
########################################
check_variables(){
    local missing=()
    for var in "${!REQUIRED_VARIABLES[@]}"; do
        if [[ -z "${!var}" ]]; then
            missing+=("$var (not set)")
        elif [[ -n "${REQUIRED_VARIABLES[$var]}" && "${!var}" != "${REQUIRED_VARIABLES[$var]}" ]]; then
            missing+=("$var (expected: ${REQUIRED_VARIABLES[$var]}, got: ${!var})")
        fi
    done
    echo "${missing[@]}"
}

########################################
# Checks the $WORKSPACE_DIR for missing directories or files
# Globals:
#   WORKSPACE_DIR
# Arguments:
# none
# Outputs:
# array of all paths missing
########################################
check_file_structure(){
    local missing=()
    for path in "${!FILE_STRUCTURE_MAP[@]}"; do
        if [[ ! -e "$path" ]]; then
            missing+=("$path (${FILE_STRUCTURE_MAP[$path]})")
        fi
    done
    echo "${missing[@]}"
}

# <<< LoonEnv


# Diagnosis Functions >>>

########################################
# Runs all diagnosis functions and prints results to stdout
# Globals:
#  none
# Arguments:
#  none
# Outputs:
# Prints results of diagnosis functions to stdout and exits with error if any problems are detected
########################################
diagnose_problems(){

    # get all invalid depenendencies
    local array_invalid_dependencies=$(check_dependencies)
    if [[ ${#array_invalid_dependencies[@]} -gt 0 ]]; then
        error "The following dependencies are missing: ${array_invalid_dependencies[*]}"
    else
        echo "All dependencies are satisfied."
    fi

    # proceed if dependencies are satisfied, otherwise exit
    if [[ ${#array_invalid_dependencies[@]} -gt 0 ]]; then
        error "Please install the missing dependencies and retry."
        exit 1
    fi

    # Check for missing or invalid variables
    local array_invalid_variables=$(check_variables)
    if [[ ${#array_invalid_variables[@]} -gt 0 ]]; then
        error "The following environment variables are missing or invalid: ${array_invalid_variables[*]}"
    else
        echo "All environment variables are set and valid."
    fi


}

########################################
# Interates over $DEPENDENCIES to determine any missing dependencies
# Globals:
# $DEPENDENCIES
# Arguments:
#  none
# Outputs:
#  array of missing dependencies
########################################
check_dependencies(){
    local missing=()
    # Iterate over the array
    for dep in "${DEPENDENCIES[@]}"; do
        if ! command -v "$dep" &> /dev/null; then
            missing+=("$dep")
        fi
    done
    echo "${missing[@]}"
}

# <<< Diagnosis Functions

# MAIN FUNCTIONS >>>

usage() {
    cat << EOF
Usage: $(basename "$0") [options]

Options:
    -h, --help      Show help
    -v, --verbose   Enable verbose mode
    --dry-run       Do not execute changes
    --version       print version
EOF
}

#######################################
# Parses arguments for script running
# Globals:
# VERBOSE
# DRY_RUN
# VERSION
# Arguments:
#   $@ Arguments to parse
# Returns:
# Nothing
#######################################
parse_runtime_arguments() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -v|--verbose)
                VERBOSE=1
                log Yapping mode activiated!
                SHIFT_ARGS_BY=$((SHIFT_ARGS_BY + 1))
                shift
                ;;
            --dry-run)
                DRY_RUN=1
                log All bark no bite mode running!
                SHIFT_ARGS_BY=$((SHIFT_ARGS_BY + 1))
                shift
                ;;
            -h|help)
                usage
                exit 0
                ;;
            --version)
                echo v"$VERSION"
                exit 0
                ;;
            *)
                error "Unknown option $1"
                exit 1
                ;;
        esac
    done
}

#######################################
# Parses arguments related to script function
# Globals:
# NONE
# Arguments:
#   $@ Arguments to parse
# Returns:
# Nothing
#######################################
parse_functional_arguments(){
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -d|--wtf|--doctor)
            diagnose_problems
            exit 0
            ;;
        *)
            error "Unknown function $1"
            exit 1;
            ;;
        esac
    done
}


# >>> MAIN <<< #
main () {
    parse_arguments $@
    
    log "Checking for existing installation lock..."

    # Check for existing installation lock
    # Put here to run immediately before any significant operations to save time
    if [[ -f "$LOCKFILE" ]]; then
        echo "Another process is already in progress. Please wait for it to finish." >&2
        exit 1
    fi
    log "No existing installation lock found. Creating installation lock..."

    # Prevent Concurrency Issues
    create_lock

    # Set trap to clean up lock file on exit
    trap cleanup EXIT

    # Code for processes go after here
    parse_functional_arguments ${@:SHIFT_ARGS_BY}
}


main $@