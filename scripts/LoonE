# Version
APP_NAME="LoonE"
VERSION="4.1.1"

# Names for Docker images and containers
ZED_IMAGE_NAME="zed-x"
LOON_E_IMAGE_NAME="loon-e"
ZED_CONTAINER_NAME="docker-zed-1"
LOON_E_CONTAINER_NAME="docker-loone-1"

# Asset directory and workspace directory with defaults
ASSET_DIR="${ASSET_DIR:-/usr/share/Loon-Env}"
LOONE_WORKSPACE_DIR="${LOONE_WORKSPACE_DIR:-$HOME/LoonE_ws}"
COMPOSE_FILE="$LOONE_WORKSPACE_DIR/docker/compose.yaml"

# Colors for stdout
PRIMARY=$(tput sgr0)
RED=$(tput setaf 9)
GREEN=$(tput setaf 2)
YELLOW=$(tput setaf 3)
ORANGE=$(tput setaf 202)
BLUE=$(tput setaf 4)
BOLD=$(tput bold)

# Global variables for build options
BUILD_PROFILE=""
BUILD_NO_CACHE=0
VERBOSE=0
DRY_RUN=0
SERVICES=() # List of services to target for start/stop/enter commands


# >>> Utility Functions <<<

#######################################
# Logs to stdout if $VERBOSE true
# Globals:
# VERBOSE
# GREEN
# BOLD
# PRIMARY
# Arguments:
#   $* - the msg
# Returns:
# Nothing
#######################################
log() {
    if [[ "$VERBOSE" -eq 1 ]]; then
        echo "${GREEN}${BOLD}[INFO] ${PRIMARY}$*"
    fi
}

#######################################
# Prints Error; does not exit
# Globals:
# RED
# BOLD
# PRIMARY
# Arguments:
#   $* - the msg
# Returns:
# Nothing
#######################################
error() {
    echo "${RED}${BOLD}[ERROR] ${PRIMARY}$*" >&2
}

#######################################
# Prints warning
# Globals:
# ORANGE
# BOLD
# PRIMARY
# Arguments:
#   $* - the msg
# Returns:
# Nothing
#######################################
warn() {
    echo "${ORANGE}${BOLD}[WARN] ${PRIMARY}$*" >&2
}

#######################################
# Runs a command unless $DRY_RUN is true then it prints it to sdtout
# Globals:
# YELLOW
# BOLD
# PRIMARY
# Arguments:
#   $1 - the command
# Returns:
# Either the string of the command or executes the command with eval
#######################################
run() {
    if [[ "$DRY_RUN" -eq 1 ]]; then
        echo "${YELLOW}${BOLD}[DRY RUN] ${PRIMARY} $*"
    else
        eval "$@"
    fi
}

################################
# Parses service targets from command-line arguments
# Globals:
#  SERVICES - An array to hold the parsed service targets
# Arguments:
#  A list of service targets (e.g., zed, loone, all)
# Outputs:
#  Populates the SERVICES array with the specified targets, handling 'all' and deduplication
target_services(){
    local targets=()
    local arg
    if [ "$#" -eq 0 ]; then
        targets=(zed loone all)
    else
        for arg in "$@"; do
            case "$arg" in
                all)
                    targets=(zed loone)
                    log "Added 'all' target, which includes: ${targets[*]}"
                    ;;
                zed|loone)
                    targets+=("$arg")
                    log "Added target: $arg"
                    ;;
                *)
                    error "Unknown stop target '$arg'. Allowed targets: zed, loone, all."
                    return 1
                    ;;
            esac
        done
    fi

    # Deduplicate while preserving first-seen order.
    local deduped=()
    local seen=""
    for arg in "${targets[@]}"; do
        case " $seen " in
            *" $arg "*) ;;
            *)
                deduped+=("$arg")
                seen="$seen $arg"
                log "Added '$arg' to deduplicated stop list."
                ;;
        esac
    done    
    SERVICES=("${deduped[@]}")
}

################################
# Checks if a specified service container is running; allows caller to handle unknown services but logs a warning for debugging
# Globals:
#  ZED_CONTAINER_NAME
#  LOON_E_CONTAINER_NAME
# Arguments:
#  service - The name of the service to check (e.g., zed, loone)
# Outputs:
#  Returns 0 if the service container is running, 1 otherwise
##################################
is_service_running() {
    local service="$1"
    local container_name=""
    case "$service" in
        zed)
            container_name="$ZED_CONTAINER_NAME"
            ;;
        loone)
            container_name="$LOON_E_CONTAINER_NAME"
            ;;
        *)
            # Let caller handle unknown services, but log a warning here for debugging purposes
            warn "Unknown service '$service' passed to is_service_running function."
            ;;
    esac
    
    return $(docker ps --filter "status=running" | grep -q "$container_name")
}

################################
# Checks if a specified Docker image exists; allows caller to handle unknown images but logs a warning
# Globals:
#  ZED_IMAGE_NAME
#  LOON_E_IMAGE_NAME
# Arguments:
#  image_name - The name of the Docker image to check (e.g., loon_zed_img, loon_e_img)
# Outputs:
#  Returns 0 if the image exists, 1 otherwise
#################################
is_image_built() {
    local image_name="$1"
    if docker images --format "{{.Repository}}" | grep -q "^${image_name}$"; then
        return 0 # Image exists
    else
        return 1 # Image does not exist
    fi
}

# >>> Argument Functions <<<

###############################
# Display usage information
# Globals:
#  None
# Arguments:
#  None
# Outputs:
#  Prints usage information to stdout
###############################
help() {
    cat <<EOF
${BOLD}Usage: LoonE ${YELLOW}[OPTIONS]

${PRIMARY}
The LoonE script is a convenient wrapper for managing the Docker environment for the Loon-E project. 
It can build the Docker image, start the container, and enter it with a single command. :)

Options:${YELLOW}
    -h, --help   ${BLUE}show this help message and exit${YELLOW}
    -f, --faq    ${BLUE}interactive FAQ to help you get started with Loon-E${YELLOW}
    -s, --start  ${BLUE}starts specified service${YELLOW}
        --stop [SERVICE ...]  ${BLUE}stop compose services${YELLOW}
    -e, --enter ${BLUE}enters specified service container${YELLOW}
    -b, --build   ${BLUE}build and run services${YELLOW}
    -q, --quack   ${BLUE}what does this do? Try it and find out!${YELLOW}
    -v, --version   ${BLUE}show version information and exit${YELLOW}
    --verbose   ${BLUE}enable verbose logging${YELLOW}
    --purge     ${BLUE}stop and remove all containers, images, and volumes associated with this project (use with caution!)${YELLOW}
    --health    ${BLUE}check health status of services${YELLOW}
    --kill-cache ${BLUE}purges everything in the Docker build cache (use with caution!)${YELLOW}
    --dry-run   ${BLUE}print commands without executing them${YELLOW}
    --where_is  ${BLUE}cd user to workspace directory${YELLOW}
${BOLD}${PRIMARY}
Build options: ${YELLOW}
    zed          ${BLUE}Builds only the "zed" service image. Accepts optional profile argument: "
    virtual" or "hardware".${YELLOW}
    loone        ${BLUE}Builds only the "loone" service image. Accepts optional profile argument
    : "virtual" or "hardware".${YELLOW}
    -n, --no-cache ${BLUE}Use Docker build without cache. Supported with "--build", "--build-zed", and "--build-loone".${YELLOW}
    -v, --virtual   ${BLUE}Sets build profile to "virtual"${YELLOW}
    -h, --hardware      ${BLUE}Sets build profile to local "zedx"${YELLOW}
${BOLD}${PRIMARY}
Service options:
    ${YELLOW}
    zed     ${BLUE}Refers to the ZED wrapper service defined in the Docker Compose file.${YELLOW}
    loone   ${BLUE}Refers to the Loon-E service defined in the Docker Compose file.${YELLOW}
    all     ${BLUE}Refers to both the ZED wrapper and Loon-E services.${YELLOW}
EOF
}

#################################
# Interactive FAQ about Loon-E
# Globals:
#  None
# Arguments:
#  None
# Outputs:
#  Prints FAQ information to stdout based on user selection
#################################
about(){
    while true; do
        cat <<'EOF'
    FAQ - Frequently Asked Questions about Loon-E
    Topics:
        1: What is LoonE?
        2: What is Loon-E?
        3: What is Loon-Env?
        4: What about the ducks?
EOF
        read -p "Enter the number of the topic you want to learn about (or 'q' to quit): " choice
        case "$choice" in
            1)
                echo "LoonE is the name of this script, which serves as a convenient wrapper for managing the Docker environment for the Loon-E project. It can build the Docker image, start the container, and enter it with a single command."
                ;;
            2)
                echo "Learn about Loon-E on https://humberasv.ca"
                ;;
            3)
                echo "Loon-Env is the name of the overall environment and project that this script is a part of. It encompasses the Docker images, containers, and tools used to develop and run the Loon-E autonomous surface vehicle."
                ;;
            4)
                echo "Loon-E is the name of the autonomous surface vehicle. It \'s named after the loon, a waterbird known for its distinctive calls and excellent swimming abilities. The name was chosen to reflect the vehicle\'s aquatic nature and its country of origin, Canada, where loons are commonly found. The name also has a playful and memorable quality, which we thought was fitting."
                ;;
            q|Q)
                echo "Exiting FAQ."
                break
                ;;
            *)
                echo "Invalid choice. Please enter a number from 1 to 4, or 'q' to quit."
                ;;
        esac
    done
}

###############################
# Display version information
# Globals:
#  VERSION
# Arguments:
#  None
# Outputs:
#  Prints version information to stdout
###############################
version() {
    echo "$APP_NAME version $VERSION"
}

###############################
# Start specified services
# Globals:
#  SERVICES - An array of services to start
#  COMPOSE_FILE - The path to the Docker Compose file
# Arguments:
#  A list of service targets (e.g., zed, loone, all)
# Outputs:
#  Starts the specified services using Docker Compose
###############################
start() {
    log "Received start command with arguments: $*"
    target_services "$@"
    log "Target services to start: ${SERVICES[*]}"
    for service in "${SERVICES[@]}"; do
        case "$service" in
            zed)
                is_service_running "zed"
                if [ $? -eq 0 ]; then
                    log "ZED wrapper service is already running. Skipping start command for this service."
                    continue
                fi
                log "Starting ZED wrapper service..."
                run "docker compose -f $COMPOSE_FILE up -d zed"
                ;;
            loone)
                is_service_running "loone"
                if [ $? -eq 0 ]; then
                    log "Loon-E service is already running. Skipping start command for this service."
                    continue
                fi
                log "Starting Loon-E service..."
                run "docker compose -f $COMPOSE_FILE up -d loone"
                ;;
            *)
                error "Unknown service '$service' passed to start function."
                ;;
        esac
    done
}

###############################
# Stop specified services
# Globals:
#  SERVICES - An array of services to stop
#  COMPOSE_FILE - The path to the Docker Compose file
# Arguments:
#  A list of service targets (e.g., zed, loone, all)
# Outputs:
#  Stops the specified services using Docker Compose, but only if they are currently running; otherwise
#  logs a warning and skips them
###############################
stop() {
    log "Received stop command with arguments: $*"
    target_services "$@"
    log "Target services to stop: ${SERVICES[*]}"
    for service in "${SERVICES[@]}"; do
        case "$service" in
            zed)
                is_service_running "zed"
                if [ $? -ne 0 ]; then
                    log "ZED wrapper service is not running. Skipping stop command for this service."
                    continue
                fi
                log "Stopping ZED wrapper service..."
                run "docker compose -f $COMPOSE_FILE stop zed"
                ;;
            loone)
                is_service_running "loone"
                if [ $? -ne 0 ]; then
                    log "Loon-E service is not running. Skipping stop command for this service."
                    continue
                fi
                log "Stopping Loon-E service..."
                run "docker compose -f $COMPOSE_FILE stop loone"
                ;;
            *)
                error "Unknown service '$service' passed to stop function."
                ;;
        esac
    done
}

#################################
# Enter the specified service container
# Globals:
#  SERVICES - An array of services to enter
#  ZED_CONTAINER_NAME - The name of the ZED wrapper service container
#  LOON_E_CONTAINER_NAME - The name of the Loon-E service container
# Arguments:
#  A list of service targets (e.g., zed, loone, all)
# Outputs:
#  Enters the specified service containers using 'docker exec' if they are running, otherwise
#  logs a warning and skips them
##################################
enter() {
    log "Received enter command with arguments: $*"
    target_services "$@"
    log "Target services to enter: ${SERVICES[*]}"
    for service in "${SERVICES[@]}"; do
        case "$service" in
            zed)
                is_service_running "zed"
                if [ $? -ne 0 ]; then
                    error "ZED wrapper service is not running. Cannot enter container for this service."
                    exit 1
                fi
                echo "Entering ZED wrapper service container..."
                echo "Maintenance commands inside this container use sudo."
                run "docker exec -it $ZED_CONTAINER_NAME bash"
                exit 0 # Exit after entering the first valid container to avoid trying to enter multiple containers in one command
                ;;
            loone)
                is_service_running "loone"
                if [ $? -ne 0 ]; then
                    error "Loon-E service is not running. Cannot enter container for this service."
                    exit 1
                fi
                echo "Entering Loon-E service container..."
                run "docker exec -it $LOON_E_CONTAINER_NAME bash"
                exit 0 # Exit after entering the first valid container to avoid trying to enter multiple containers in one command
                ;;
            *)
                error "Unknown service '$service' passed to enter function."
                exit 1
                ;;
        esac
    done
}

################################
# Build Docker images for specified services
# Globals:
#  SERVICES - An array of services to build
# Arguments:
# virtual or zedx - Mandatory argument specifying the build profile to use (e.g., virtual or zedx)
# with_cache - Mandatory 1 or 0 to specify whether to use Docker build cache
# target_services - An array of services to build (e.g., zed, loone, all)
# Outputs:
#  Builds the Docker images for the specified services using the specified build profile and cache options
##################################
build() {
    log "Received build command with arguments: $*"
    local profile=""
    local with_cache=1

    if [ "$#" -eq 0 ]; then
        error "No build options specified. Please specify a build profile and target services."
        error "Use '-h' or '--help' to see usage information."
        return 1
    fi

    if [[ "$1" != --* ]]; then
        error "Build options must be specified before target services."
        error "Use '-h' or '--help' to see usage information."
        return 1
    fi

    if [[ "$1" == --no-cache || "$1" == -n ]]; then
       with_cache=0
       log "Set build to use no cache"
    fi

    if [[ "$1" == --virtual || "$1" == -v ]]; then
        profile="ZED_WRAPPER_GIT_REF=virtual"
        log "Set build profile to 'virtual'"

    elif [[ "$1" == --hardware || "$1" == -h ]]; then
        profile="ZED_WRAPPER_GIT_REF=zedx"
        log "Set build profile to 'zedx'"
    else
        error "Build profile is required. Please specify either '--virtual' or '--hardware'."
        return 1
    fi

    target_services "${@:2}"
    log "Target services to build: ${SERVICES[*]}"
    
    for service in "${SERVICES[@]}"; do
        case "$service" in
            zed)
                log "Building ZED wrapper service image with profile '$profile' and cache option '$with_cache'..."
                run "docker compose -f $COMPOSE_FILE build $( [ $with_cache -eq 0 ] && echo '--no-cache' ) --build-arg $profile zed"
                ;;
            loone)
                log "Building Loon-E service image with profile '$profile' and cache option '$with_cache'..."
                run "docker compose -f $COMPOSE_FILE build $( [ $with_cache -eq 0 ] && echo '--no-cache' ) --build-arg $profile loone"
                ;;
            *)
                error "Unknown service '$service' passed to build function."
                ;;
        esac
    done
}

################################
# Prints a fun ASCII art of a duck to the terminal
# Globals:
#  None
# Arguments:
#  None
# Outputs:
#  Prints ASCII art of a duck to stdout
##################################
quack() {
    case $((RANDOM % 4)) in
        0)
            echo "The duck is sleeping... Zzz..."
            ;;
        1)
        echo "The duck is awake and quacking! Quack quack!"
    cat <<'EOF'
⠀⠀⠀⠀⠀⠀⣀⣤⣶⣶⣤⡀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀
⠀⠀⠀⠀⢀⣾⠛⠁⢰⣧⡈⢻⣦⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀
⠀⠀⠀⠀⢸⣇⣼⡀⠻⠟⠁⠀⢻⡆⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀
⠀⠀⠀⢀⡞⣹⠙⣧⡀⠀⠀⡀⢸⡇⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀
⠀⣀⡴⠋⠀⣀⣴⣿⡷⠴⠞⠁⢸⡇⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀
⢾⣁⣀⡤⠾⠛⠁⣸⠀⠀⠀⠀⢸⡇⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀
⠈⠁⠀⠀⠀⠀⢠⡟⠀⠀⠀⠀⣾⠃⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀
⠀⠀⠀⠀⠀⣠⣿⠁⠀⠀⠀⢀⣿⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀
⠀⠀⠀⠀⣰⡿⠁⠀⠀⠀⠀⠀⢿⣶⠶⠿⠟⠿⠿⣶⣦⣄⡀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀
⠀⠀⠀⣼⠟⠀⠀⠀⠀⠀⠀⠀⠈⠻⣄⠀⠀⠀⠀⠀⠈⠙⠛⠿⠶⣶⣤⡀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀
⠀⠀⣸⡏⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠁⢀⣀⣠⣤⣤⣤⣤⣤⣀⠀⠉⠙⠳⢦⣄⡀⣀⣤⣀⣀⡄⠀
⠀⢀⣿⠁⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠈⠉⠁⠀⠀⠀⠀⠀⠈⠉⠻⢶⣀⠀⠀⠈⠉⢁⠈⠏⣿⣁⠀
⠀⢸⣿⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠻⣦⣀⣀⡴⠁⠀⠀⢙⣿⡾
⠀⠘⣿⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠉⠉⠀⠀⣀⣠⡾⠟⠃
⠀⠀⠹⣧⡀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⣀⣀⣀⡔⢊⣵⠞⠋⠁⠀⠀⠀
⠀⠀⠀⠙⠿⣦⣀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⡠⠚⠉⠀⣠⣴⠟⠁⠀⠀⠀⠀⠀⠀
⠀⠀⠀⠀⠀⠈⠙⠳⠶⣤⣤⣄⣀⠀⠀⠀⠀⠀⠀⠀⢤⣤⣴⠊⣁⣤⠶⠛⠉⠀⠀⠀⠀⠀⠀⠀⠀⠀
⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠉⠙⠛⡷⢶⡶⠶⠤⠔⢺⠃⡟⠉⠉⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀
⠀⠀⠀⠀⠀⠀⠀⠀⢀⣀⣀⣀⠀⢰⡇⠀⡇⠀⠀⠀⢸⠀⠃⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀
⠀⠀⠀⠀⠀⠀⠀⠀⠈⣹⣤⣭⠿⠟⣃⣾⠋⠀⠀⢠⡟⢸⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀
⠀⠀⠀⠀⠀⠀⠀⠀⠀⠁⠈⠉⠙⠛⢋⣿⣙⣶⣾⡿⢷⡿⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀
⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠐⠛⠛⠻⠧⠶⠾⠛⠁⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀
EOF
            ;;
        2)
    cat <<'EOF'
        The duck is rubber
         __
       <(o )___
        ( ._> /
         `---'
EOF
            ;;
        3)
        echo "The duck was a lie! It was a Loon the whole time!"
            ;;
        *)
            echo "The duck is confused... Quack?"
            ;;
    esac
}

################################# 
# Purge all Loon-Env Docker images and containers with confirmation prompt
# Globals:
#  COMPOSE_FILE - The path to the Docker Compose file
# Arguments:
#  None
# Outputs:
#  Prompts the user for confirmation, then purges all Docker images and containers related to
#  Loon-Env if confirmed; otherwise, cancels the purge
##################################
purge_docker(){
    while true; do
        read -p "Are you sure you want to purge all Loon-Env Docker images and containers? This action cannot be undone. ${GREEN}(y/N)${PRIMARY} " -n 1 -r
        echo
        if [[ "$REPLY" =~ ^[Yy]$ ]]; then
            log "Purging all Loon-Env Docker images and containers..."
            run "docker compose -f $COMPOSE_FILE down --rmi all --volumes --remove-orphans"
            break
        else
            log "Purge cancelled. No Docker images or containers were removed."
            break
        fi
    done
}

purge_cache(){
    while true; do
        read -p "Are you sure you want to purge all Loon-Env Docker build cache? This action cannot be undone. ${GREEN}(y/N)${PRIMARY} " -n 1 -r
        echo
        if [[ "$REPLY" =~ ^[Yy]$ ]]; then
            log "Purging all Loon-Env Docker build cache..."
            run "docker builder prune --all --force"
            break
        else
            log "Purge cancelled. No Docker build cache was removed."
            break
        fi
    done
}

################################
# Check health status of services defined in Docker Compose file
# Globals:
#  COMPOSE_FILE - The path to the Docker Compose file
# Arguments:
#  None
# Outputs:
#  Prints the health status of each service defined in the Docker Compose file to stdout
##################################
health(){
    log "Checking health status of services..."
    run "docker compose -f $COMPOSE_FILE ps"
}


################################
# Parses command-line arguments and dispatches to the appropriate function
# Globals:
#  None
# Arguments:
#  A list of command-line arguments (e.g., --build --virtual zed)
# Outputs:
#  Calls the appropriate function based on the parsed arguments, or prints an error message for unknown options
##################################
parse_arguments() {
    while [[ "$#" -gt 0 ]]; do
        case "$1" in
            --where_is)
                echo "Changing directory to workspace: $LOONE_WORKSPACE_DIR"
                echo "This is where docker-compose.yaml and related files are located."
                echo "Primary volume locations for the containers are also located here, so this is a good place to be!"
                echo "Note: This does not start a shell in the workspace, it just changes the current working directory for this script to the workspace directory."
                cd "$LOONE_WORKSPACE_DIR"
                return 0
                ;;
             --verbose)
                VERBOSE=1
                shift
                ;;
            --dry-run)
                DRY_RUN=1
                shift
                ;;
            -h|--help)
                help
                return 0
                ;;
            -f|--faq)
                about
                return 0
                ;;
            -s|--start)
                shift
                start "$@"
                return 0
                ;;
            --stop)
                shift
                stop "$@"
                return 0
                ;;
            -e|--enter)
                shift
                enter "$@"
                return 0
                ;;
            -b|--build)
                shift
                build "$@"
                return 0
                ;;
            -q|--quack)
                quack
                return 0
                ;;
            -v|--version)
                version
                return 0
                ;;
            --purge)
                purge_docker
                return 0
                ;;
            --kill-cache)
                purge_cache
                return 0
                ;;
            --health)
                is_service_running "zed"
                zed_running=$?
                is_service_running "loone"
                loone_running=$?
                is_image_built "$ZED_IMAGE_NAME"
                zed_built=$?
                is_image_built "$LOON_E_IMAGE_NAME"
                loone_built=$?

                printf "${BLUE}${BOLD}Service Health Status:${PRIMARY}\n"
                printf "+-----------------+---------+---------+\n"
                printf "| %-15s | %-7s | %-7s |\n" "Service" "Built" "Running"
                printf "+-----------------+---------+---------+\n"
                printf "| %-15s | %-7s | %-7s |\n" "ZED Wrapper" "$( [ $zed_built -eq 0 ] && echo ${GREEN}Yes || echo ${RED}No )" "$( [ $zed_running -eq 0 ] && echo ${GREEN}Yes || echo ${RED}No )"
                printf "| %-15s | %-7s | %-7s |\n" "Loon-E"      "$( [ $loone_built -eq 0 ] && echo ${GREEN}Yes || echo ${RED}No )" "$( [ $loone_running -eq 0 ] && echo ${GREEN}Yes || echo ${RED}No )"
                printf "+-----------------+---------+---------+\n"
                return 0
                ;;
            *)
                error "Unknown option '$1'."
                error "Use '-h' or '--help' to see usage information."
                return 1
                ;;
        esac
    done
}

parse_arguments "$@"