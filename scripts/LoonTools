# <<< X11 Utility Functions

# LoonENV >>>

########################################
# Checks if the global variables are set and valid
# Uses the REQUIRED_VARIABLES array to determine what should be set and if it should be a specific value
# Globals:
#  REQUIRED_VARIABLES
#  NOT_CHECKED
#  MISSING
#  INVALID
#  VALID
# Arguments:
#  none
# Outputs:
# modified REQUIRED_VARIABLES_STATUS with missing, valid, invalid status
# 
########################################
check_variables(){
    log "Checking required environment variables..."
    for var in "${!REQUIRED_VARIABLES[@]}"; do
        log "Checking variable $BLUE $var $PRIMARY..."
        local expected_value="${REQUIRED_VARIABLES[$var]}"
        local actual_value=$(printenv "$var" 2>/dev/null)
        log "Expected value: $GREEN $expected_value $PRIMARY"

        if [[ "$expected_value" == "$actual_value" ]]; then
            log "Variable $GREEN $var $PRIMARY is valid."
            REQUIRED_VARIABLE_STATUS["$var"]="$VALID"
        elif [[ -z "$actual_value" ]]; then
            log "Variable $RED $var $PRIMARY is missing."
            REQUIRED_VARIABLE_STATUS["$var"]="$MISSING"
        else
            log "Variable $ORANGE $var $PRIMARY is invalid. Actual value: $RED $actual_value $PRIMARY"
            REQUIRED_VARIABLE_STATUS["$var"]="$INVALID"
        fi
    done
}

########################################
# Checks the $WORKSPACE_DIR for missing directories or files
# Uses the FILE_STRUCTURE_MAP to determine what should be there and if it is a file or directory
# Globals:
#   FILE_STRUCTURE_MAP
# Arguments:
# none
# Outputs:
# modified FILE_STRUCTURE_MAP with missing and invalid status
########################################
check_file_structure(){
    log "Checking file structure in $WORKSPACE_DIR..."
    for path in "${!CORRECT_FILE_STRUCTURE[@]}"; do
        local expected_type="${CORRECT_FILE_STRUCTURE[$path]}"
        if [[ ! -e "$path" ]]; then
            log "Path $RED $path $PRIMARY is missing."
            FILE_STRUCTURE_STATUS["$path"]="$MISSING"
        elif [[ "$expected_type" -eq "$DIRECTORY_TYPE" && ! -d "$path" ]]; then
            log "Path $ORANGE $path $PRIMARY is invalid. Expected a directory but found a file."
            FILE_STRUCTURE_STATUS["$path"]="$INVALID"
        elif [[ "$expected_type" -eq "$FILE_TYPE" && ! -f "$path" ]]; then
            log "Path $ORANGE $path $PRIMARY is invalid. Expected a file but found a directory."
            FILE_STRUCTURE_STATUS["$path"]="$INVALID"
        else
            log "Path $GREEN $path $PRIMARY is valid."
            FILE_STRUCTURE_STATUS["$path"]="$VALID"
        fi
    done
}

# <<< LoonEnv


# Diagnosis Functions >>>

########################################
# Runs all diagnosis functions and prints results to stdout
# Globals:
#  none
# Arguments:
#  none
# Outputs:
# Prints results of diagnosis functions to stdout and exits with error if any problems are detected
########################################
diagnose_problems(){
    if in_container; then
        log "Running diagnostics for container environment..."
        repair_dpkg_state
        check_variables
    else
        log "Running diagnostics for host environment..."
        check_variables
        check_file_structure
        check_commands
        check_zed_daemon
    fi
    # Print summary of results
    echo "Diagnosis Summary:"

    echo "${BOLD}Environment Variables:${PRIMARY}"
    for var in "${!REQUIRED_VARIABLES[@]}"; do
        local status="${REQUIRED_VARIABLE_STATUS[$var]}"
        if [[ "$status" -eq "$VALID" ]]; then
            echo "  $GREEN $var: Valid $PRIMARY"
        elif [[ "$status" -eq "$MISSING" ]]; then
            echo "  $RED $var: Missing $PRIMARY"
        elif [[ "$status" -eq "$INVALID" ]]; then
            echo "  $ORANGE $var: Invalid (actual value: ${!var}) $PRIMARY"
        else
            echo "  $YELLOW $var: Not Checked $PRIMARY"
        fi
    done

    echo "${BOLD}File Structure:${PRIMARY}"
    for path in "${!CORRECT_FILE_STRUCTURE[@]}"; do
        local status="${FILE_STRUCTURE_STATUS[$path]}"
        if [[ "$status" -eq "$VALID" ]]; then
            echo "  $GREEN $path: Valid $PRIMARY"
        elif [[ "$status" -eq "$MISSING" ]]; then
            echo "  $RED $path: Missing $PRIMARY"
        elif [[ "$status" -eq "$INVALID" ]]; then
            echo "  $ORANGE $path: Invalid (expected type: ${CORRECT_FILE_STRUCTURE[$path]}) $PRIMARY"
        else
            echo "  $YELLOW $path: Not Checked $PRIMARY"
        fi
    done

    echo "${BOLD}Commands:${PRIMARY}"
    for cmd in "${!REQUIRED_COMMANDS[@]}"; do
        local status="${REQUIRED_COMMANDS[$cmd]}"
        if [[ "$status" -eq "$VALID" ]]; then
            echo "  $GREEN $cmd: Available $PRIMARY"
        elif [[ "$status" -eq "$MISSING" ]]; then
            echo "  $RED $cmd: Missing $PRIMARY"
        else
            echo "  $YELLOW $cmd: Not Checked $PRIMARY"
        fi
    done
}

########################################
# Interates over $REQUIRED_COMMANDS to determine any missing dependencies
# Globals:
# $REQUIRED_COMMANDS
# NOT_CHECKED
# MISSING
# VALID
# Arguments:
#  none
# Outputs:
#  modified $REQUIRED_COMMANDS with missing and valid status
########################################
check_commands(){
    log "Checking for required commands..."
    local missing_commands=()
    for cmd in "${!REQUIRED_COMMANDS[@]}"; do
        log "Checking command $BLUE $cmd $PRIMARY..."
        if command -v "$cmd" >/dev/null 2>&1; then
            log "Command $GREEN $cmd $PRIMARY is available."
            REQUIRED_COMMANDS["$cmd"]="$VALID"
        else
            log "Command $RED $cmd $PRIMARY is missing."
            REQUIRED_COMMANDS["$cmd"]="$MISSING"
            missing_commands+=("$cmd")
        fi
    done
}

# <<< Diagnosis Functions

#######################################
# Detects if in a container environment
# Globals:
# Arguments:
#   None
# Returns:
# 0 if in container, 1 if not
#######################################
in_container() {
    if [[ $(printenv "CONTAINER" 2>/dev/null) == "true" ]]; then
        return 0
    fi
    if [ -f "/.dockerenv" ]; then
        return 0
    fi
    if grep -qE '/docker|/lxc|/kubepods' /proc/1/cgroup 2>/dev/null; then
        return 0
    fi
    return 1
}

########################################
# Repairs stale dpkg-statoverride entry for plocate if it exists, which can cause issues with rosdep and apt operations in the container
# Globals:
# Arguments:
#   None
# Returns:
# Nothing, modifies dpkg-statoverride if necessary
########################################
repair_dpkg_state() {
    if sudo grep -qE '(^|[[:space:]])plocate([[:space:]]|$)' /var/lib/dpkg/statoverride 2>/dev/null; then
        printf '[INFO] Repairing stale dpkg-statoverride entry for plocate\n'
        sudo sed -i.bak '/[[:space:]]plocate[[:space:]]/d' /var/lib/dpkg/statoverride
    fi
}
################################
# Attempts to build colcon workspace
# Globals:
# Arguments:
#   service - loone or zed
# Outputs:
# Runs colcon build with appropriate arguments for LoonE
################################
build_colcon(){
    local service="${1:-loone}"
    log "Starting colcon build for service: $BLUE $service $PRIMARY..."
    if in_container; then
        log "Running build commands for container environment..."

        
        local build_command='source /opt/ros/humble/setup.bash && repair_dpkg_state && sudo apt-get update && rosdep update && repair_dpkg_state && sudo rosdep install --from-paths src --ignore-src -r -y && for d in /home/robo/ros2_ws /home/robo/loone_ws /home/robo/zed_ws; do [ -d "$d" ] && sudo chown -R robo:robo "$d"; done && export ZED_DIR=/usr/local/zed && export CMAKE_PREFIX_PATH=/usr/local:/usr/local/zed:$CMAKE_PREFIX_PATH && sudo chown -R root:zed /usr/local/zed || true && sudo chmod -R g+rX /usr/local/zed || true && colcon build --parallel-workers 4 --symlink-install --event-handlers console_direct+ --base-paths src --cmake-clean-cache --cmake-args -DCMAKE_BUILD_TYPE=Release -DCMAKE_PREFIX_PATH=/usr/local -DZED_SDK_ROOT=/usr/local/zed -DCMAKE_LIBRARY_PATH=/usr/local/cuda/lib64/stubs -DCMAKE_CXX_FLAGS="-Wl,--allow-shlib-undefined" --no-warn-unused-cli && sudo rm -rf /var/lib/apt/lists/*'

        if [[ "$service" == "loone" ]]; then
            log "Running build commands for LoonE service..."
            run "${build_command}"
        elif [[ "$service" == "zed" ]]; then
            log "Running build commands for ZedX service..."
            run "${build_command}"
        else # not a valid service
            error "Unknown service: $BLUE $service $PRIMARY. Valid options are 'loone' or 'zed'."
            exit 1
        fi
        
    else # if not in container
       error "Colcon build should be run inside the container environment. Please run this command after entering the container."
       exit 1
    fi
}

# MAIN FUNCTIONS >>>

usage() {
    cat << EOF
Usage: $(basename "$0") [options]

Options:
    -d, --wtf, --doctor   Run diagnostics to check for common issues
    -c, --colcon          Build the colcon workspace (should be run inside container)
    -h, --help      Show help
    -v, --verbose   Enable verbose mode
    --dry-run       Do not execute changes
    --version       print version
EOF
}

#######################################
# Parses arguments for script running
# Globals:
# VERBOSE
# DRY_RUN
# VERSION
# Arguments:
#   $@ Arguments to parse
# Returns:
# Nothing
#######################################
parse_runtime_arguments() {
    while [[ $# -gt $(($SHIFT_ARGS_BY - 1)) ]]; do
        case "$1" in
            -v|--verbose)
                VERBOSE=1
                log 'Yapping mode activiated!'
                SHIFT_ARGS_BY=$((SHIFT_ARGS_BY + 1))
                shift
                ;;
            --dry-run)
                DRY_RUN=1
                log All bark no bite mode running!
                SHIFT_ARGS_BY=$((SHIFT_ARGS_BY + 1))
                shift
                ;;
            -h|help)
                usage
                exit 0
                ;;
            --version)
                echo v"$VERSION"
                exit 0
                ;;
            *)
                log "Unknown option $1 probbably a functional argument..."
                ;;
        esac
    done
}

#######################################
# Parses arguments related to script function
# Globals:
# NONE
# Arguments:
#   $@ Arguments to parse
# Returns:
# Nothing
#######################################
parse_functional_arguments(){
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -d|--wtf|--doctor)
            diagnose_problems
            exit 0
            ;;
            -c|--colcon)
            build_colcon
            exit 0
            ;;
        *)
            error "Unknown function $1"
            exit 1;
            ;;
        esac
    done
}


# >>> MAIN <<< #
main () {
    parse_runtime_arguments $@
    
    log "Checking for existing installation lock..."

    # Check for existing installation lock
    # Put here to run immediately before any significant operations to save time
    if [[ -f "$LOCKFILE" ]]; then
        echo "Another process is already in progress. Please wait for it to finish." >&2
        exit 1
    fi
    log "No existing installation lock found. Creating installation lock..."

    # Prevent Concurrency Issues
    create_lock

    # Set trap to clean up lock file on exit
    trap cleanup EXIT

    # Code for processes go after here
    parse_functional_arguments ${@:SHIFT_ARGS_BY}
}


main $@